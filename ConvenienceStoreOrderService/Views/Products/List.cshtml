@model ConvenienceStoreOrderService.Models.ViewModels.ProductSearchCriteria
@{
    ViewBag.Title = "商品列表";
}

<div class="container mt-4">

    <h2 class="mb-3">商品列表</h2>

    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            商品搜尋
        </div>

        <div class="card-body">
            @using (Html.BeginForm("List", "Products", FormMethod.Get))
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">關鍵字</label>
                        @Html.TextBoxFor(
                            m => m.ProductKeyword,
                            new { @class = "form-control", placeholder = "請輸入商品名稱" }
                        )
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">最低價格</label>
                        @Html.TextBoxFor(
                            m => m.MinPrice,
                            new { @class = "form-control", type = "number", placeholder = "最低價" }
                        )
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">最高價格</label>
                        @Html.TextBoxFor(
                            m => m.MaxPrice,
                            new { @class = "form-control", type = "number", placeholder = "最高價" }
                        )
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">上架狀態</label>
                        @Html.DropDownListFor(
                            m => m.IsActive,
                            Model.IsActiveOptions,
                            "請選擇上架狀態",
                            new { @class = "form-select" }
                        )
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            搜尋
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model.Products == null || !Model.Products.Any())
    {
        <div class="alert alert-secondary">
            目前沒有符合條件的商品。
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.Products)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">
                                @item.ProductName
                            </h5>

                            <p class="card-text text-muted mb-2">
                                商品編號：@item.ProductId
                            </p>

                            <p class="fs-5 fw-bold mb-3">
                                NT$ @item.Price
                            </p>

                            @using (Html.BeginForm("PlaceOrder", "Orders", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()

                                @Html.Hidden("ProductId", item.ProductId)

                                @* 先寫死測試用 *@
                                @Html.Hidden("BuyerUserId", 1)
                                @Html.Hidden("SellerUserId", 2)
                                @*@Html.Hidden("PaymentMethod", 1)*@

                                <div class="mb-3">
                                    <label class="form-label">購買數量</label>
                                    <input type="number"
                                           name="Quantity"
                                           value="1"
                                           min="1"
                                           class="form-control" />
                                </div>
                                <div class="mb-3">
    <label for="PaymentMethod" class="form-label">付款方式</label>

    <select name="PaymentMethod" id="PaymentMethod" class="form-select" required>
        <option value="">請選擇付款方式</option>
        <option value="COD">取貨付款</option>
        <option value="CreditCard">信用卡</option>
        <option value="LinePay">LinePay</option>
    </select>

    <div class="form-text">
        請選擇本次訂單的付款方式
    </div>
</div>

                                <button type="submit" class="btn btn-success w-100 mt-auto">
                                    立即下單
                                </button>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
