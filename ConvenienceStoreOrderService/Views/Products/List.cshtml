
@model ConvenienceStoreOrderService.Models.ViewModels.ProductSearchCriteria
@{
    ViewBag.Title = "List";
}

<h2>商品列表</h2>
@Html.ValidationSummary()

@using (Html.BeginForm("List", "Products", FormMethod.Get))
{
    <div>
        關鍵字：
        @Html.TextBoxFor(m => m.ProductKeyword)
    </div>
    <div>
        最低價格：
        @Html.TextBoxFor(m => m.MinPrice)
    </div>

    <div>
        最高價格：
        @Html.TextBoxFor(m => m.MaxPrice)
    </div>
    <div>
        上架狀態：
        @Html.DropDownListFor(
            m => m.IsActive,
            Model.IsActiveOptions,
            "請選擇上架狀態"
        )
    </div>

    <button type="submit">搜尋</button>
}

<hr />

<table>
    <thead>
        <tr>
            <th>商品名稱</th>
            <th>價格</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Products)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Price</td>
            </tr>
        }
    </tbody>
</table>
