@model List<ConvenienceStoreOrderService.Models.ViewModels.OrderViewModel>
<h2>訂單資訊</h2>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<table class="table">
    <thead>
        <tr>
            <th>訂單編號</th>
            <th>訂單來源</th>
            <th>付款方式</th>
            <th>建立時間</th>
            <th>運費</th>
            <th>訂單總金額</th>
            <th>取消原因</th>
            <th>操作</th>
            <th>訂單狀態</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderNo</td>
                <td>@order.OrderSource</td>
                <td>@order.PaymentMethod</td>
                <td>@order.CreatedAt</td>
                <td>@order.ShippingFee</td>
                <td>@order.OrderTotal</td>
                <td>@order.CancelReason</td>
                <td>
                    @using (Html.BeginForm("MarkReadyToShip", "Orders", FormMethod.Post))
                    {
                        @Html.Hidden("orderId", order.OrderId)

                        <button type="submit" class="btn btn-primary">
                            改為待出貨
                        </button>
                    }
                    @using (Html.BeginForm("MarkShipped", "Orders", FormMethod.Post))
                    {
                        @Html.Hidden("orderId", order.OrderId)
                <button type="submit" class="btn btn-warning">
                    改為已出貨
                </button>
                            }
                    </td>
                <td>@order.OrderStatusName</td>
            </tr>
        }
    </tbody>
</table>
